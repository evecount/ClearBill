
{
  "entities": {
    "Organization": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Organization",
      "type": "object",
      "description": "Represents a tenant organization within the ClearBill application. Stores core profile, branding, and strategic DNA.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "logoUrl": { "type": "string", "format": "uri" },
        "contactEmail": { "type": "string", "format": "email" },
        "addressLine1": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "postalCode": { "type": "string" },
        "country": { "type": "string" },
        "taxId": { "type": "string", "description": "Business registration or tax number (e.g., UEN, GST, VAT, EIN)." },
        "currency": { "type": "string", "default": "USD" },
        "industry": { "type": "string" },
        "missionStatement": { "type": "string" },
        "brandColor": { "type": "string" },
        "slug": { "type": "string" },
        "website": { "type": "string", "format": "uri" },
        "growthStrategy": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "contactEmail", "createdAt", "updatedAt"]
    },
    "Client": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Client",
      "type": "object",
      "description": "Represents a client who receives invoices from an organization.",
      "properties": {
        "id": { "type": "string" },
        "organizationId": { "type": "string" },
        "name": { "type": "string" },
        "company": { "type": "string", "description": "The name of the client's company or organization." },
        "contactEmail": { "type": "string", "format": "email" },
        "addressLine1": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "organizationId", "name", "contactEmail", "createdAt", "updatedAt"]
    },
    "Proposal": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Proposal",
      "type": "object",
      "description": "Represents a project proposal drafted with AI.",
      "properties": {
        "id": { "type": "string" },
        "organizationId": { "type": "string" },
        "clientId": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["Draft", "Sent", "Accepted", "Declined"] },
        "content": { "type": "string" },
        "estimatedAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "organizationId", "clientId", "title", "status", "createdAt", "updatedAt"]
    },
    "Invoice": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Invoice",
      "type": "object",
      "description": "Represents an invoice with an optional strategic outcome contract.",
      "properties": {
        "id": { "type": "string" },
        "organizationId": { "type": "string" },
        "clientId": { "type": "string" },
        "number": { "type": "string" },
        "issueDate": { "type": "string", "format": "date" },
        "dueDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Draft", "Pending", "Paid", "Overdue"] },
        "totalAmount": { "type": "number" },
        "taxRate": { "type": "number" },
        "contractContent": { "type": "string", "description": "AI-drafted strategic outcome agreement text." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "organizationId", "clientId", "number", "issueDate", "dueDate", "status", "totalAmount", "createdAt", "updatedAt"]
    },
    "InvoiceLineItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "InvoiceLineItem",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "invoiceId": { "type": "string" },
        "description": { "type": "string" },
        "quantity": { "type": "number" },
        "unitPrice": { "type": "number" },
        "amount": { "type": "number" }
      },
      "required": ["id", "invoiceId", "description", "quantity", "unitPrice", "amount"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/organizations/{organizationId}": {
      "schema": { "$ref": "#/backend/entities/Organization" },
      "description": "Root tenant organization."
    },
    "/organizations/{organizationId}/clients/{clientId}": {
      "schema": { "$ref": "#/backend/entities/Client" },
      "description": "Clients of the organization."
    },
    "/organizations/{organizationId}/proposals/{proposalId}": {
      "schema": { "$ref": "#/backend/entities/Proposal" },
      "description": "Proposals for clients."
    },
    "/organizations/{organizationId}/invoices/{invoiceId}": {
      "schema": { "$ref": "#/backend/entities/Invoice" },
      "description": "Invoices with outcome contracts."
    },
    "/organizations/{organizationId}/invoices/{invoiceId}/lineItems/{lineItemId}": {
      "schema": { "$ref": "#/backend/entities/InvoiceLineItem" },
      "description": "Invoice line items."
    }
  }
}
